// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

generator client2 {
  provider     = "prisma-client-js"
  output       = "../generated/prisma2"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id         Int    @id @default(autoincrement())
  nombre     String @db.VarChar(50)
  contrasena String @db.VarChar(50)

  rolesAsignados RolAsignado[]
}

model Rol {
  id          Int    @id @default(autoincrement())
  descripcion String @unique @db.VarChar(20)

  rolesAsignados RolAsignado[]
}

model RolAsignado {
  idra      Int @id @default(autoincrement())
  usuarioId Int
  rolId     Int

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, rolId])
}

model Provincia {
  id                   Int    @id @default(autoincrement())
  nombre               String @unique @db.VarChar(50)
  lealtad              Int
  prosperidadEconomica Int
  impuestos            Int
  conflictosInternos   Int
  riesgoRebelion       Int

  legiones   Legion[]
  gobernador Gobernador?
}

model Legion {
  id             Int    @id @default(autoincrement())
  nombre         String @unique @db.VarChar(50)
  numeroSoldados Int
  experiencia    Int
  moral          Int
  estado         String @db.VarChar(20)

  provinciaId Int?
  provincia   Provincia? @relation(fields: [provinciaId], references: [id])
}

model Gobernador {
  id               Int    @id @default(autoincrement())
  nombre           String @db.VarChar(50)
  edad             Int
  nivelCompetencia Int
  nivelCorrupcion  Int
  tiempoCargo      Int

  provinciaId Int?       @unique
  provincia   Provincia? @relation(fields: [provinciaId], references: [id])
}
